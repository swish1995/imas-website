---
import Layout from '@/layouts/Layout.astro';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';
import { Separator } from '@/components/ui/separator';
const base = import.meta.env.BASE_URL;
---

<Layout title="IMAS - 동영상 기반 AI 자세 분석 및 인체공학 평가 도구">
  <!-- Hero -->
  <section class="relative overflow-hidden py-24 md:py-36">
    <div class="absolute inset-0 bg-gradient-to-br from-[#0d1b2a] via-background to-background"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-[#4a9eff]/10 via-transparent to-transparent"></div>
    <div class="relative mx-auto max-w-6xl px-6 text-center">
      <Badge variant="outline" className="mb-6 border-[#4a9eff]/40 bg-[#4a9eff]/10 text-[#4a9eff] text-sm px-4 py-1.5">
        특허 출원중
      </Badge>
      <h1 class="mx-auto max-w-4xl text-5xl font-extrabold tracking-tight md:text-7xl leading-tight">
        작업 자세 평가,<br />
        <span class="bg-gradient-to-r from-[#4a9eff] to-[#2d7cd6] bg-clip-text text-transparent">10분에서 1초로</span>
      </h1>
      <p class="mx-auto mt-8 max-w-2xl text-lg text-muted-foreground leading-relaxed md:text-xl">
        동영상 한 편으로 5가지 국제 표준 인체공학 평가를 자동 수행합니다.<br />
        AI가 실시간으로 자세를 분석하고, 근골격계 질환 위험을 사전에 파악합니다.
      </p>
      <div class="mt-12 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href={`${base}download/`}>
          <Button className="h-13 px-8 text-base font-semibold bg-[#4a9eff] hover:bg-[#3a8eef] text-white shadow-lg shadow-[#4a9eff]/25">
            무료 다운로드
          </Button>
        </a>
        <a href={`${base}features/`}>
          <Button variant="outline" className="h-13 px-8 text-base font-semibold">
            기능 살펴보기
          </Button>
        </a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-y border-border/40 py-14">
    <div class="mx-auto grid max-w-5xl grid-cols-2 gap-8 px-6 md:grid-cols-4">
      {[
        { value: '5가지', label: '국제 표준 평가' },
        { value: '33개', label: '관절점 자동 감지' },
        { value: '실시간', label: 'AI 자세 분석' },
        { value: '30~40%', label: '직업성 질환 중 MSD' },
      ].map((stat) => (
        <div class="text-center">
          <div class="text-3xl font-bold text-[#4a9eff] md:text-4xl">{stat.value}</div>
          <div class="mt-2 text-sm text-muted-foreground">{stat.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Why IMAS -->
  <section class="py-24">
    <div class="mx-auto max-w-6xl px-6">
      <h2 class="mb-4 text-center text-3xl font-bold md:text-4xl">왜 <span class="text-[#4a9eff]">IMAS</span>인가?</h2>
      <p class="mx-auto mb-14 max-w-2xl text-center text-muted-foreground">
        기존 수동 평가의 한계를 AI 기술로 해결합니다
      </p>
      <div class="grid gap-6 md:grid-cols-2">
        <Card className="border-border/60">
          <CardHeader>
            <CardTitle className="text-muted-foreground text-lg">기존 방식</CardTitle>
          </CardHeader>
          <CardContent>
            <ul class="space-y-4 text-sm text-muted-foreground">
              <li class="flex items-start gap-3">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-red-500/10 text-xs text-red-400">✕</span>
                <span>수동 각도 측정 — 자세당 <strong class="text-foreground">10~20분</strong> 소요</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-red-500/10 text-xs text-red-400">✕</span>
                <span>고가의 모션캡처 장비 또는 웨어러블 센서 필요</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-red-500/10 text-xs text-red-400">✕</span>
                <span>평가사의 숙련도에 따른 결과 편차</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-red-500/10 text-xs text-red-400">✕</span>
                <span>단일 평가 지표에 의존</span>
              </li>
            </ul>
          </CardContent>
        </Card>
        <Card className="border-[#4a9eff]/30 bg-[#4a9eff]/5">
          <CardHeader>
            <CardTitle className="text-[#4a9eff] text-lg">IMAS</CardTitle>
          </CardHeader>
          <CardContent>
            <ul class="space-y-4 text-sm">
              <li class="flex items-start gap-3">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-[#4ade80]/10 text-xs text-[#4ade80]">✓</span>
                <span>AI 실시간 자동 산출 — <strong class="text-[#4a9eff]">즉시 결과 확인</strong></span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-[#4ade80]/10 text-xs text-[#4ade80]">✓</span>
                <span>일반 카메라 영상 하나면 충분, 전용 장비 불필요</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-[#4ade80]/10 text-xs text-[#4ade80]">✓</span>
                <span>객관적이고 재현 가능한 평가 결과</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-[#4ade80]/10 text-xs text-[#4ade80]">✓</span>
                <span>RULA/REBA/OWAS/NLE/SI <strong class="text-[#4a9eff]">5가지 동시 평가</strong></span>
              </li>
            </ul>
          </CardContent>
        </Card>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="border-t border-border/40 py-24">
    <div class="mx-auto max-w-6xl px-6">
      <h2 class="mb-14 text-center text-3xl font-bold md:text-4xl">어떻게 동작하나요?</h2>
      <div class="grid gap-4 md:grid-cols-5">
        {[
          { step: '1', icon: '🎥', title: '영상 입력', desc: '동영상 또는 이미지를 로드합니다' },
          { step: '2', icon: '🦴', title: '자세 감지', desc: 'AI가 33개 관절점을 자동 추출합니다' },
          { step: '3', icon: '📐', title: '각도 산출', desc: '13개 관절의 굴곡 각도를 계산합니다' },
          { step: '4', icon: '📊', title: '평가 수행', desc: '5가지 국제 표준 평가를 자동 산출합니다' },
          { step: '5', icon: '📋', title: '보고서', desc: 'Excel 보고서로 내보냅니다' },
        ].map((item) => (
          <Card className="text-center border-border/60 hover:border-[#4a9eff]/30 transition-colors">
            <CardContent className="pt-6">
              <div class="mb-3 text-4xl">{item.icon}</div>
              <Badge variant="secondary" className="mb-2 text-[#4a9eff] bg-[#4a9eff]/10 border-0">
                STEP {item.step}
              </Badge>
              <h3 class="mb-1 font-semibold">{item.title}</h3>
              <p class="text-xs text-muted-foreground leading-relaxed">{item.desc}</p>
            </CardContent>
          </Card>
        ))}
      </div>
      <div class="mt-10 text-center">
        <a href={`${base}assessments/`}>
          <Button variant="outline" className="h-13 px-8 text-base font-semibold">
            5가지 평가 방법 자세히 보기
          </Button>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-border/40 py-24">
    <div class="mx-auto max-w-2xl px-6 text-center">
      <h2 class="text-3xl font-bold md:text-4xl">무료로 시작해보세요</h2>
      <p class="mt-6 text-muted-foreground leading-relaxed">
        RULA 평가와 기본 분석 기능은 무료로 제공됩니다.<br />
        등록 버전에서는 REBA, OWAS, NLE, SI를 포함한 모든 기능을 사용할 수 있습니다.
      </p>
      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href={`${base}download/`}>
          <Button className="h-13 px-10 text-base font-semibold bg-[#4a9eff] hover:bg-[#3a8eef] text-white shadow-lg shadow-[#4a9eff]/25">
            다운로드
          </Button>
        </a>
        <a href={`${base}contact/`}>
          <Button variant="outline" className="h-13 px-10 text-base font-semibold">
            라이센스 문의
          </Button>
        </a>
      </div>
    </div>
  </section>
</Layout>
